generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DAppPartner {
  id            String           @id @default(uuid())
  name          String
  apiKey        String           @unique
  createdAt     DateTime         @default(now())
  allowedPackages AllowedPackage[]
  transactionLogs TransactionLog[]
  walletDailyUsages WalletDailyUsage[]
}

model AllowedPackage {
  id              String        @id @default(uuid())
  packageId       String
  dAppPartnerId   String
  dAppPartner     DAppPartner   @relation(fields: [dAppPartnerId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([packageId, dAppPartnerId])
}

model TransactionLog {
  id              String        @id @default(uuid())
  walletAddress   String
  packageId       String
  txDigest        String?
  gasUsed         Float?
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
  dAppPartnerId   String
  dAppPartner     DAppPartner   @relation(fields: [dAppPartnerId], references: [id])
}

model WalletDailyUsage {
  id              String        @id @default(uuid())
  walletAddress   String
  date            DateTime      @default(now())
  txCount         Int           @default(0)
  dAppPartnerId   String
  dAppPartner     DAppPartner   @relation(fields: [dAppPartnerId], references: [id])

  @@unique([walletAddress, date, dAppPartnerId])
}

