# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opensignal?schema=public"

# Shinami Gas Station API
SHINAMI_GAS_API_KEY="your_shinami_gas_api_key_here"

# Sui RPC URL (Testnet)
